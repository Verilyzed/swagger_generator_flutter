{
  "openapi": "3.1.0",
  "info": { "title": "Edge Cases 3.1", "version": "1.0.0" },
  "webhooks": {
    "ping": { "post": { "responses": { "204": { "description": "ok" } } } }
  },
  "paths": {
    "/ping": {
      "get": {
        "operationId": "getPing",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Ping" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
      "Ping": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "TypeShapes": {
        "type": "object",
        "properties": {
          "strOrNull": { "type": ["string", "null"] },
          "strOrInt": { "type": ["string", "integer"] },
          "strOrIntOrNull": { "type": ["string", "integer", "null"] },
          "anyOfNull": { "anyOf": [{ "type": "string" }, { "type": "null" }] }
        }
      },
      "ThreeOneConstructs": {
        "type": "object",
        "properties": {
          "tuple": {
            "type": "array",
            "prefixItems": [{ "type": "string" }, { "type": "integer" }]
          },
          "constField": { "const": "FIXED" },
          "constTyped": { "type": "string", "const": "FIXED" },
          "emptySchema": {},
          "exampledField": { "type": "string", "examples": ["a", "b"] }
        }
      },
      "Cat": { "type": "object", "properties": { "meow": { "type": "boolean" } } },
      "Dog": { "type": "object", "properties": { "bark": { "type": "boolean" } } },
      "PetOneOf": {
        "oneOf": [
          { "$ref": "#/components/schemas/Cat" },
          { "$ref": "#/components/schemas/Dog" }
        ]
      },
      "PetDiscriminated": {
        "oneOf": [
          { "$ref": "#/components/schemas/Cat" },
          { "$ref": "#/components/schemas/Dog" }
        ],
        "discriminator": {
          "propertyName": "kind",
          "mapping": {
            "cat": "#/components/schemas/Cat",
            "dog": "#/components/schemas/Dog"
          }
        }
      },
      "Base": {
        "type": "object",
        "properties": { "id": { "type": "string" } },
        "required": ["id"]
      },
      "Derived": {
        "allOf": [
          { "$ref": "#/components/schemas/Base" },
          { "type": "object", "properties": { "extra": { "type": "string" } } }
        ]
      },
      "Holder": {
        "type": "object",
        "properties": {
          "pet": { "$ref": "#/components/schemas/PetOneOf" },
          "derived": { "$ref": "#/components/schemas/Derived" }
        }
      }
    }
  }
}
